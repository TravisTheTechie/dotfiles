if command -v brew >/dev/null 2>&1; then
  OPENJDK_PREFIX="$(brew --prefix openjdk 2>/dev/null)"
  if [ -n "$OPENJDK_PREFIX" ] && [ -d "$OPENJDK_PREFIX/libexec/openjdk.jdk/Contents/Home" ]; then
    export JAVA_HOME="$OPENJDK_PREFIX/libexec/openjdk.jdk/Contents/Home"
  fi
  unset OPENJDK_PREFIX
fi

# less pager settings
# R: enable color
# F: quit if fits on one screen
# X: don't clear on exit
export LESS="-RFX"
