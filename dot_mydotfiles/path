if [ -d /snap/bin ]; then
  export PATH=$PATH:/snap/bin
fi

if [ -d ~/.local/bin ]; then
  export PATH=~/.local/bin:$PATH
fi

# java
if [ -d /opt/homebrew/Cellar/openjdk/25/libexec/openjdk.jdk/Contents/Home ]; then
  export PATH=/opt/homebrew/Cellar/openjdk/25/libexec/openjdk.jdk/Contents/Home/bin:$PATH
fi

# rustup
if [ -d "$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/bin" ]; then
  export PATH="$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/bin:$PATH"
fi

# rust / cargo
if [ -d "~/.cargo/bin" ]; then
    export PATH=$HOME/.cargo/bin:$PATH
fi