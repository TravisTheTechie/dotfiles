source_if_readable() {
  [ -r "$1" ] && source "$1"
}

# tools
source_if_readable "$HOME/.mydotfiles/nvm"
source_if_readable "$HOME/.mydotfiles/neovim"

# my stuff last so it doesn't get overridden
source_if_readable "$HOME/.mydotfiles/aliases"
source_if_readable "$HOME/.mydotfiles/path"

# env
source_if_readable "$HOME/.mydotfiles/env"

# zsh
source_if_readable "$HOME/.mydotfiles/zsh"

# starship
source_if_readable "$HOME/.mydotfiles/starship"

# zellij
source_if_readable "$HOME/.mydotfiles/zellij"
